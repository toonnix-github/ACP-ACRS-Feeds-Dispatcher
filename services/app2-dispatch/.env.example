# App2 – Dispatch Service
# Copy to .env and fill in values for local development.
# Never commit .env to the repository.

# Server
PORT=8080
NODE_ENV=development

# AWS
AWS_REGION=eu-west-1
AWS_ACCOUNT_ID=

# SQS
SQS_QUEUE_URL=https://sqs.eu-west-1.amazonaws.com/{account}/feeds-dispatcher-sqs-dev
SQS_MAX_MESSAGES=10
SQS_WAIT_TIME_SECONDS=20
SQS_VISIBILITY_TIMEOUT=300

# S3
S3_BUCKET_NAME=feeds-dispatcher-raw-dev
S3_PRESIGNED_URL_TTL_SECONDS=86400

# EventBridge
EVENTBRIDGE_BUS_NAME=feeds-dispatcher-dev
EVENTBRIDGE_SOURCE=feeds-dispatcher

# Auth
AUTH_ENABLED=true
